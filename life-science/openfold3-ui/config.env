# PFUI configuration. Sourced by the launch scripts and docker compose.
# Edit the paths/image to match your environment.

# Repo root. The SLURM launch scripts set this to the submit dir automatically;
# the `:-` default is used by docker compose and bare-metal runs.
PFUI_DIR="${PFUI_DIR:-$HOME/pfui}"

# Where OpenFold3 writes outputs (CIFs + confidence JSONs).
RESULTS_DIR=$HOME/pfui_results

# Model/weight cache (HuggingFace + OpenFold weights). Prefer fast local storage.
CACHE_DIR=$HOME/.cache/openfold3

# OpenFold3 inference image.
OF3_DOCKERFILE=$PFUI_DIR/configs/OpenFold3/Dockerfile.rocm
DOCKER_IMAGE=pfui/openfold3:triton-release

# Ports
PFUI_PORT=8060
INFERENCE_PORT=8061
